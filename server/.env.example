NODE_ENV=development
PORT=3000

# ── 런타임 접속 (PM2에 포함) ─────────────────────────────────────

# 인증된 API용 (counter_app 역할, strict RLS)
DATABASE_URL=postgresql://counter_app:change_this_app_password@localhost:5432/counter_system

# auth 전용 (counter_auth 역할, 오픈 RLS — signup/login/refresh/slug 조회)
DATABASE_AUTH_URL=postgresql://counter_auth:change_this_auth_password@localhost:5432/counter_system

# ── 마이그레이션 전용 (PM2에 포함하지 않음) ──────────────────────

# CREATEROLE 권한 보유 계정. npm run migrate 실행 시에만 사용.
DATABASE_SUPERUSER_URL=postgresql://counter_superuser:dev_superuser_pass@localhost:5432/counter_system

# ── JWT ──────────────────────────────────────────────────────────

JWT_SECRET=change_this_jwt_secret_at_least_32_characters
JWT_REFRESH_SECRET=change_this_refresh_secret_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Solapi (Phase 2) ────────────────────────────────────────────
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# 플랫폼 공유 채널 (테넌트 미설정 시 기본값)
# SOLAPI_PLATFORM_PFID=
# SOLAPI_PLATFORM_SENDER=
# SOLAPI_PLATFORM_TEMPLATE_ISSUE=

# ── Superadmin (Phase 3) ─────────────────────────────────────────
# /api/superadmin/* 접근에 사용하는 정적 시크릿
SUPERADMIN_SECRET=change_this_superadmin_secret_at_least_32_chars

# ── Redis (Standard 단계) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379
